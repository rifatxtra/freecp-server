# ============================================================
#  FreeCP — Server Configuration
#  Copy to: /opt/freecp/config/freecp.conf
#  Permissions: chmod 600
# ============================================================

# ── MariaDB root password ─────────────────────────────────────
DB_ROOT_PASSWORD=

# ── Admin SMTP ────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_ENCRYPTION=ssl
SMTP_FROM=noreply@rifatxtra.com
SMTP_FROM_NAME=FreeCP

# ── Backup VPS (optional) ─────────────────────────────────────
BACKUP_ENABLED=false
BACKUP_VPS_HOST=
BACKUP_VPS_USER=root
BACKUP_VPS_PORT=22
BACKUP_VPS_PATH=/backups/freecp
